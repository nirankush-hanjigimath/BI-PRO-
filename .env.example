# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key (free — no billing card required)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Discord Webhook URL
# How to get one:
#   1. Open Discord → your server → a channel (e.g. #trade-alerts)
#   2. Channel Settings → Integrations → Webhooks → New Webhook
#   3. Copy the Webhook URL and paste it here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: override the config.yaml path
# MONITOR_CONFIG=config.yaml
